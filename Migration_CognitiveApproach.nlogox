<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="false">
  <code><![CDATA[;; ==========================================================
;; MIGRATION AS COGNITIVE GAP (Carling & Schewel, 2018)
;; ==========================================================
;; Lydia Teinfalt for CSS 635   Last Updated: 5/1/2026

globals [
  flow-to-trapped   ;; Count agents becoming Involuntary Non-Migrants
  flow-to-migrant   ;; Count agents becoming Voluntary Migrants
  total-migrations  ;; Total migrated
]

turtles-own [
  ;; --- ASPIRATIONS (Scale 0 - 10) ---
  asp-safety      ; Physiological / Desire for safer environment
  asp-quality     ; Safety / Desire for better living conditions
  asp-economic    ; Safety / Desire for better income
  asp-family      ; Love & Belonging / Join family or friends
  asp-adventure   ; Self-actualization / New experiences
  total-aspiration 
  aspiration
  next-aspiration
  ability-growth-potential

  
   ;; --- ABILITIES (Scale 0 - 10) ---
  abil-financial  ; Afford migration cost
  abil-legal      ; Obtain visas/permits
  abil-human      ; Education and skills
  abil-social     ; Network to help
  abil-info       ; Knowledge on how to migrate
  abil-family     ; Freedom from family obligations
  total-ability
  
  ;; --- STATE ---
  previous-status    ; The actual current state
  migration-status  ; "voluntary-migrant", "acquiescent-migrant", "involuntary-non-migrant", "voluntary-non-migrant"
]

;; ==========================================================
;; SETUP PROCEDURES
;; ==========================================================

to setup
  random-seed global-seed
  clear-all
  setup-patches
  setup-turtles
  reset-ticks
end

to setup-patches
     ;; X-axix = Aspiration, Right half = High Aspiration / Left half = low Aspiration
     ;; Y-axis = Ability,  Upper half = High Ability / Lower half = Low Ability
  
  ask patches [
    ifelse pxcor > 0 [
      ifelse pycor > 0 [ set pcolor sky - 2 ] [ set pcolor red + 3.5 ]
    ] [
      ifelse pycor > 0 [ set pcolor yellow + 3 ] [ set pcolor gray + 3 ]
    ]
    if pxcor = 0 or pycor = 0 [ set pcolor black ]
  ]
end

to setup-turtles

    let asp-min 0 let asp-max 10
    let abil-min 0 let abil-max 10 
    
    ;; Interpret the initial-aspiration-level / initial-ability-level 
    ;; All = 1 - 10, High = 5.1 - 10, Low = 1 - 5
    (ifelse
      initial-aspiration-level = "High" [ set asp-min 5.1 set asp-max 10 ]
      initial-aspiration-level = "Low"  [ set asp-min 0   set asp-max 5  ]
    )
  
    (ifelse
      initial-ability-level = "High" [ set abil-min 5.1 set abil-max 10 ]
      initial-ability-level = "Low"  [ set abil-min 0   set abil-max 5  ]
     )
  
  create-turtles num-turtles [    
    set shape "default"
    set size 1.0
    setxy random-xcor random-ycor
    set ability-growth-potential (random-float 1.5 + 0.5) 
    
    ;; Initialize Aspirations
    set aspiration (asp-min + random-float (asp-max - asp-min))
    set next-aspiration (asp-min + random-float (asp-max - asp-min))
    set asp-safety (asp-min + random-float (asp-max - asp-min))
    set asp-quality (asp-min + random-float (asp-max - asp-min))
    set asp-economic (asp-min + random-float (asp-max - asp-min))
    set asp-family (asp-min + random-float (asp-max - asp-min))
    set asp-adventure (asp-min + random-float (asp-max - asp-min))
    
    ;; Initialize Abilities
    set abil-financial (abil-min + random-float (abil-max - abil-min))
    set abil-legal (abil-min + random-float (abil-max - abil-min))
    set abil-human (abil-min + random-float (abil-max - abil-min))
    set abil-social (abil-min + random-float (abil-max - abil-min))
    set abil-info (abil-min + random-float (abil-max - abil-min))
    set abil-family (abil-min + random-float (abil-max - abil-min))
    
    ;; Only link to turtles within 3 patches
    let network-friends other turtles in-radius 1.5
    if any? network-friends [
      ;; Create a link with only 2 or less nearby turtles
      create-links-with n-of (min list 2 count network-friends) network-friends [
        set color grey
      ]
    ]
    
    recalculate-metrics
    determine-status
    set previous-status migration-status
    update-agent-position

  ]
end

;; ==========================================================
;; GO PROCEDURES
;; ==========================================================

to go
  
  update-aspiration-socially
  increase-ability
    
  ask turtles [

    set aspiration next-aspiration

    recalculate-metrics
    determine-status
    migrate
  ]
  update-link-visibility 

  tick
end
to update-link-visibility
  ifelse show-links
    [ ask links [ show-link ] ] 
    [ ask links [ hide-link ] ]
end

to determine-status
  ifelse total-aspiration > 5 [
    
    ;; RIGHT SIDE: HIGH ASPIRATION
    ifelse total-ability > 5 [
      set migration-status "voluntary-migrant"         ;; High aspiration, high ability
      set color green
    ] [
      set migration-status "involuntary-non-migrant"   ;; The Cognitive Gap: Want to move, unable to
      set color red  
    ]
    
  ] [
   
    ;; LEFT SIDE: LOW ASPIRATION
    
    ifelse total-ability > 5 [
      set migration-status "voluntary-non-migrant" ;; Content agents Low aspiration
      set color cyan     
    ] [
      set migration-status "acquiescent-non-migrant"   ;; Resigned: Low potential, no desire
      set color yellow            ;; Slight shade shift if you want a hint of difference
    ]
  ]
  
  if previous-status != migration-status [
    if migration-status = "involuntary-non-migrant" [ 
      set flow-to-trapped flow-to-trapped + 1 
    ]
    if migration-status = "voluntary-migrant" [ 
      set flow-to-migrant flow-to-migrant + 1
      set total-migrations total-migrations + 1 ;; Cumulative counter
    ]
  ]

end

to recalculate-metrics
  ;; Maslow's logic
  ifelse asp-safety >= 5 [
    ;;total-aspiration is the average of the 5 internal needs + the 1 socialized drive
    ;;set total-aspiration mean (list asp-safety asp-quality asp-economic asp-family asp-adventure aspiration)]
    ;; 70% internal dimensions, 30% social network influence
    set total-aspiration (0.7 * mean (list asp-safety asp-quality asp-economic asp-family asp-adventure)) + (0.3 * aspiration)]
    [set total-aspiration asp-safety ]

  
  ;; Mixed ability logic (min to represent bottleneck (20%) and mean = compensating factors (80%))
  let my-abilities (list abil-financial abil-legal abil-human abil-social abil-info abil-family)
  
  ;; Giving less weight to the lower bounds of abilities dimensions and more weight (80%) to the average as a compensating control
  set total-ability (0.2 * min (my-abilities)) + (0.8 * mean(my-abilities))
  
end

to migrate
  ;; Agents jitter slightly to look alive, but stay in their conceptual area
  right random 360
  forward random-float 0.1
  let scale-x ((max-pxcor - 0.5) / 5)
  let scale-y ((max-pycor - 0.5) / 5)
  
  let true-x (total-aspiration - 5) * scale-x
  let true-y (total-ability - 5) * scale-y
  
  facexy true-x true-y
  if distancexy true-x true-y > 0.1 [ forward 0.05 ]
end

to update-agent-position
  ;; Only used in set up and external shocks
  let scale-x ((max-pxcor - 0.5) / 5)
  let scale-y ((max-pycor - 0.5) / 5)
  let true-x (total-aspiration - 5) * scale-x
  let true-y (total-ability - 5) * scale-y
  let target-x median (list min-pxcor true-x max-pxcor)
  let target-y median (list min-pycor true-y max-pycor)
  setxy target-x target-y
end

;; ==========================================================
;; ASPIRATION & ABILITY DYNAMICS
;; ==========================================================

to update-aspiration-socially
  ;; 1. Calculate the macro-level impact (Global Diaspora Signal)
  let total-pop count turtles
  let diaspora-signal 0
  if total-pop > 0 [
    set diaspora-signal (count turtles with [migration-status = "voluntary-migrant"] / total-pop)
  ]
  
  ask turtles [
    ;; global diaspora influence
    let diaspora-pull (diaspora-signal * 0.1)
    
    ;; Meso networks
    let my-network link-neighbors 
    let migrated-friends count my-network with [migration-status = "voluntary-migrant"]
    
    ;; Use the slider to weight the direct impact of migrated friends
    let net-boost (migrated-friends * network-strength) 

    ifelse any? my-network [
      ;; Peer pressure: seeing if friends have high vs low total aspirations
      let peer-weight (network-strength * 0.1) 
      let positive-influence count my-network with [aspiration > 5]
      let negative-influence count my-network with [aspiration < 5]
      
      ;; Combine local peer pressure, the global signal, and the specific network boost
      let total-change ((positive-influence - negative-influence) * peer-weight) + diaspora-pull + net-boost
      set next-aspiration (aspiration + total-change)
    ] 
    [
      ;; If isolated, only the global signal influences them
      set next-aspiration (aspiration + diaspora-pull)
    ]

    ;; 2. Bound values between 1 and 10
    set next-aspiration median (list 1 next-aspiration 10)
    
  ]
end

to increase-ability
  ask turtles [
    ;; Simulate slow growth in human capital (learning)
    ;; and financial capital (savings)
    let random-luck random-float 0.01
    set abil-human (abil-human + 0.004)
    set abil-financial (abil-financial + (random-luck * ability-growth-potential))
    ifelse migration-status = "involuntary-non-migrant" or migration-status = "acquiescent-non-migrant" [
      ;; Involuntary mobile povery trap
      set abil-financial (abil-financial - 0.005)] 
    [set abil-financial (abil-financial + 0.005)]
    
    ;; Cap values at 10 to stay within your scale
    if abil-human > 10 [ set abil-human 10 ]
    if abil-financial > 10 [ set abil-financial 10 ]
]

end


to apply-economic-shock
  ;; Simulate a sudden economic downturn at the origin
  ask turtles [
    ;; Economic downturn at the origin increases migrant's aspiration to seek opportunities elsewhere
    let shock-magnitude (11 - abil-financial) * 0.3
    set asp-economic min (list 10 (asp-economic + 2 + random-float 3))
    
    
    ;; Despite increase in aspiration, ability to migrate is negatively impacted by economic downturn
    set abil-financial max (list 0 (abil-financial - shock-magnitude))
    set abil-human max (list 0 (abil-human - shock-magnitude))
    set abil-social max (list 0 (abil-social - shock-magnitude))
    set abil-info max (list 0 (abil-info - shock-magnitude))
    set abil-legal max (list 0 (abil-legal - shock-magnitude)) 
    set abil-family max (list 0 (abil-family - shock-magnitude))
      
  
    recalculate-metrics
    determine-status
    update-agent-position
  ]
end

to apply-shock-border-closure
  ;; Simulate a sudden policy change restricting legal migration for everyone
  ask turtles with [migration-status = "voluntary-migrant"] [
    ;; Legal ability plummets (Bounded to a minimum of 0)
    set abil-legal (abil-legal - 5 - random-float 3)
    if abil-legal < 0 [ set abil-legal 0 ]
    
    recalculate-metrics
    determine-status
    update-agent-position
  ]
end

to apply-shock-deportation
  ask turtles [
    ; High intensity shock to safety
    set asp-safety (asp-safety - 5 - random-float 2)
    if asp-safety < 0 [ set asp-safety 0 ]
    
    ; high intensity shock to legal ability
    set abil-legal (abil-legal - 5 - random-float 3)
    if abil-legal < 0 [ set abil-legal 0 ]
    
    if migration-status = "involuntary-non-migrant" or migration-status = "acquiescent-non-migrant" 
      ;; The "Trap" logic: Savings are spent on survival, not growth
      [ set abil-financial (abil-financial - 0.004) ]

    recalculate-metrics
    determine-status
    update-agent-position
  ]
end





]]></code>
